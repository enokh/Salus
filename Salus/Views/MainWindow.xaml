<Window x:Class="Salus.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Salus.Views"
        xmlns:vm="clr-namespace:Salus.ViewModels"
        Title="Salus"
        Width="900" Height="620"
        MinWidth="720" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:HistoryViewModel}">
            <views:HistoryView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TrendsViewModel}">
            <views:TrendsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Logo -->
                <StackPanel DockPanel.Dock="Top" Margin="16,20,16,16">
                    <TextBlock Text="Salus" FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBrush}"/>
                    <TextBlock x:Name="ProfileNameText" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>

                <!-- Nav -->
                <StackPanel DockPanel.Dock="Top">
                    <Button Content="History" Style="{StaticResource NavButton}"
                            Command="{Binding ShowHistoryCommand}"/>
                    <Button Content="Trends" Style="{StaticResource NavButton}"
                            Command="{Binding ShowTrendsCommand}"/>
                    <Button Content="Settings" Style="{StaticResource NavButton}"
                            Command="{Binding ShowSettingsCommand}"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="16,0,16,16">
                    <Button Content="Check In Today" Style="{StaticResource PrimaryButton}"
                            Click="CheckIn_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Content Area -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentView}" Margin="0"/>
    </Grid>
</Window>
