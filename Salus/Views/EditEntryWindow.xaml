<Window x:Class="Salus.Views.EditEntryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Entry"
        Width="480" Height="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Edit Entry" FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14">
                    <Run Text="{Binding EntryDate, StringFormat='{}{0:MMMM d, yyyy}'}"/>
                </TextBlock>
            </StackPanel>

            <!-- Sleep -->
            <StackPanel Grid.Row="1" Margin="0,0,0,16">
                <TextBlock Style="{StaticResource FieldLabel}" Text="Sleep Hours"/>
                <TextBox Style="{StaticResource StandardTextBox}"
                         Text="{Binding SleepHours, UpdateSourceTrigger=PropertyChanged}"
                         Tag="e.g. 7.5"/>
            </StackPanel>

            <!-- Exercise -->
            <StackPanel Grid.Row="2" Margin="0,0,0,16">
                <TextBlock Style="{StaticResource FieldLabel}" Text="Exercise Duration (minutes)"/>
                <TextBox Style="{StaticResource StandardTextBox}"
                         Text="{Binding ExerciseDuration, UpdateSourceTrigger=PropertyChanged}"
                         Tag="e.g. 30"/>
            </StackPanel>

            <!-- Weight -->
            <StackPanel Grid.Row="3" Margin="0,0,0,16">
                <TextBlock Style="{StaticResource FieldLabel}" Text="Weight (kg)"/>
                <TextBox Style="{StaticResource StandardTextBox}"
                         Text="{Binding WeightKg, UpdateSourceTrigger=PropertyChanged}"
                         Tag="e.g. 72.5"/>
            </StackPanel>

            <!-- Mood -->
            <StackPanel Grid.Row="4" Margin="0,0,0,16">
                <TextBlock Style="{StaticResource FieldLabel}" Text="Mood"/>
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="EMood1" Tag="1" Content="😞" Style="{StaticResource MoodButton}" Click="MoodButton_Click"/>
                    <Button x:Name="EMood2" Tag="2" Content="😕" Style="{StaticResource MoodButton}" Click="MoodButton_Click"/>
                    <Button x:Name="EMood3" Tag="3" Content="😐" Style="{StaticResource MoodButton}" Click="MoodButton_Click"/>
                    <Button x:Name="EMood4" Tag="4" Content="😊" Style="{StaticResource MoodButton}" Click="MoodButton_Click"/>
                    <Button x:Name="EMood5" Tag="5" Content="😄" Style="{StaticResource MoodButton}" Click="MoodButton_Click"/>
                </StackPanel>
            </StackPanel>

            <!-- Exercises -->
            <StackPanel Grid.Row="5" Margin="0,0,0,16">
                <TextBlock Style="{StaticResource FieldLabel}" Text="Exercises"/>
                <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="6"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="8">
                    <ItemsControl ItemsSource="{Binding Exercises}" MaxHeight="100">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Exercise.Name}"
                                          IsChecked="{Binding IsSelected}"
                                          Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,3"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </StackPanel>

            <!-- Actions -->
            <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Style="{StaticResource SecondaryButton}"
                        Click="Cancel_Click" Margin="0,0,8,0"/>
                <Button Content="Save Changes" Style="{StaticResource PrimaryButton}"
                        Command="{Binding SaveChangesCommand}"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>
