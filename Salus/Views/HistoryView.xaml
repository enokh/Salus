<UserControl x:Class="Salus.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:system="clr-namespace:System;assembly=mscorlib"
             Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Calendar -->
        <StackPanel Grid.Column="0">
            <TextBlock Text="History" FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>
            <Calendar SelectedDate="{Binding SelectedDate, Mode=TwoWay}"
                      DisplayDateEnd="{x:Static system:DateTime.Today}"/>
        </StackPanel>

        <!-- Entry Detail -->
        <ScrollViewer Grid.Column="1" Margin="24,0,0,0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Date Header -->
                <TextBlock FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16">
                    <Run Text="{Binding SelectedDate, StringFormat='{}{0:MMMM d, yyyy}'}"/>
                </TextBlock>

                <!-- No Entry State -->
                <Border Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"
                        Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="24">
                    <TextBlock Text="No entry for this day" FontSize="15"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                </Border>

                <!-- Skipped State -->
                <Border Visibility="{Binding IsSkipped, Converter={StaticResource BoolToVis}}"
                        Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="24">
                    <StackPanel>
                        <TextBlock Text="Day Skipped" FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <Button Content="Fill In Retroactively" Style="{StaticResource SecondaryButton}"
                                HorizontalAlignment="Center" Command="{Binding EditCommand}"/>
                    </StackPanel>
                </Border>

                <!-- Entry Data -->
                <StackPanel Visibility="{Binding HasEntry, Converter={StaticResource BoolToVis}}">
                    <StackPanel Visibility="{Binding IsSkipped, Converter={StaticResource InverseBoolToVis}}">

                        <!-- Photo -->
                        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                            <Image Source="{Binding CurrentEntry.PhotoPath}" Height="160" Stretch="Uniform"
                                   HorizontalAlignment="Center"/>
                        </Border>

                        <!-- Metrics Grid -->
                        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,12">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Sleep"/>
                                    <TextBlock FontSize="20" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               Text="{Binding CurrentEntry.SleepHours, StringFormat='{}{0:F1} hrs', TargetNullValue='—'}"/>
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,12">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Exercise"/>
                                    <TextBlock FontSize="20" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               Text="{Binding CurrentEntry.ExerciseDuration, StringFormat='{}{0} min', TargetNullValue='—'}"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,12">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Weight"/>
                                    <TextBlock FontSize="20" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               Text="{Binding CurrentEntry.WeightKg, StringFormat='{}{0:F1} kg', TargetNullValue='—'}"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,12">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Mood"/>
                                    <TextBlock FontSize="20" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               Text="{Binding CurrentEntry.MoodRating, TargetNullValue='—'}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Edit Button -->
                        <Button Content="Edit Entry" Style="{StaticResource SecondaryButton}"
                                HorizontalAlignment="Left" Command="{Binding EditCommand}"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
