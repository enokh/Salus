<Window x:Class="Salus.Views.CameraPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Take Photo"
        Width="640" Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="Black" CornerRadius="8">
            <Image x:Name="CameraFeed" Stretch="Uniform"/>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
            <Button Content="Capture" Style="{StaticResource PrimaryButton}"
                    Click="Capture_Click" Margin="0,0,8,0" Width="120"/>
            <Button Content="Cancel" Style="{StaticResource SecondaryButton}"
                    Click="Cancel_Click" Width="120"/>
        </StackPanel>
    </Grid>
</Window>
