<Application x:Class="Salus.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:Salus.Helpers"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/LightTheme.xaml"/>
                <ResourceDictionary Source="Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <helpers:BoolToVisibilityConverter x:Key="BoolToVis"/>
            <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
